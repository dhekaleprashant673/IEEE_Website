datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

model Contact {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contacts")
}

model NewsletterSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("newsletter_subscribers")
}

model TeamMember {
  id          String   @id @default(uuid())
  name        String
  designation String
  image       String
  linkedin    String?
  github      String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("team_members")
}

model GalleryImage {
  id        String   @id @default(uuid())
  imageUrl  String   @map("image_url")
  title     String
  category  String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("gallery_images")
}

model Feature {
  id          String   @id @default(uuid())
  title       String
  description String
  icon        String
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("features")
}

model Statistic {
  id        String   @id @default(uuid())
  title     String
  value     String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("statistics")
}
